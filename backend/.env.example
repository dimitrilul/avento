AVENTO_ENVIRONMENT=development
AVENTO_DATABASE_URL=postgresql+psycopg://avento:change-me@localhost:5432/avento
AVENTO_SECRET_KEY=replace-with-at-least-32-random-characters
AVENTO_BOOTSTRAP_INVITE_CODE=replace-with-a-one-time-bootstrap-code
AVENTO_ACCESS_TOKEN_MINUTES=15
AVENTO_REFRESH_TOKEN_DAYS=30
AVENTO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
AVENTO_TIMEZONE=Europe/Berlin
AVENTO_UPLOAD_DIR=./data/uploads
AVENTO_MAX_UPLOAD_BYTES=20971520
AVENTO_MAX_AVATAR_BYTES=10485760
AVENTO_AVATAR_SIZE_PX=512
AVENTO_MAX_AVATAR_PIXELS=20000000
AVENTO_AUTO_CREATE_SCHEMA=false

# Read-only MCP server
AVENTO_MCP_ACCESS_TOKEN_MINUTES=10
AVENTO_MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://[::1]

# Weather: "open_meteo" or "disabled"
AVENTO_WEATHER_PROVIDER=open_meteo
AVENTO_WEATHER_TIMEOUT_SECONDS=8
AVENTO_WEATHER_ROUTE_SAMPLES=7

# AI: without a key, deterministic local coaching summaries and chat answers are used.
AVENTO_OPENAI_API_KEY=
AVENTO_OPENAI_BASE_URL=https://api.openai.com/v1
AVENTO_OPENAI_MODEL=gpt-5.4-mini
AVENTO_AI_TIMEOUT_SECONDS=20
