# Copy this file to .env before starting the production stack.
POSTGRES_DB=avento
POSTGRES_USER=avento
# Für die zusammengesetzte Datenbank-URL nur URL-sichere Zeichen verwenden,
# beispielsweise einen langen zufälligen alphanumerischen Wert.
POSTGRES_PASSWORD=replace-with-a-long-random-alphanumeric-password
SECRET_KEY=replace-with-at-least-32-random-characters
PUBLIC_URL=http://localhost
TIMEZONE=Europe/Berlin

# Optional AI integration. Without a key, Avento creates a local deterministic summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: open_meteo (Standard) oder disabled
WEATHER_PROVIDER=open_meteo

# Optional reverse geocoding. Deliberately disabled because route coordinates are personal data.
# For LocationIQ, create a token and consciously enable transmission of sparse route samples.
REVERSE_GEOCODING_PROVIDER=disabled
REVERSE_GEOCODING_BASE_URL=https://eu1.locationiq.com/v1
LOCATIONIQ_API_KEY=
REVERSE_GEOCODING_USER_AGENT=Avento/0.1 (self-hosted route insights)

# Read-only MCP. MCP_ALLOWED_ORIGINS should include PUBLIC_URL when the Web UI
# is used to request short-lived client tokens.
MCP_ACCESS_TOKEN_MINUTES=10
MCP_ALLOWED_ORIGINS=http://localhost
# Optional canonical MCP resource URI. By default it is PUBLIC_URL plus
# /api/v1/mcp/rpc.
MCP_RESOURCE_URI=
MCP_OAUTH_ACCESS_TOKEN_MINUTES=15
MCP_OAUTH_REFRESH_TOKEN_DAYS=30

# Optional bootstrap invitation code for the first account.
BOOTSTRAP_INVITE_CODE=replace-with-a-one-time-bootstrap-code
