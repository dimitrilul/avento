# Copy this file to .env before starting the production stack.
POSTGRES_DB=avento
POSTGRES_USER=avento
POSTGRES_PASSWORD=replace-with-a-strong-database-password
SECRET_KEY=replace-with-at-least-32-random-characters
PUBLIC_URL=http://localhost

# Optional AI integration. Without a key, Avento creates a local deterministic summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional bootstrap invitation code for the first account.
BOOTSTRAP_INVITE_CODE=replace-with-a-one-time-bootstrap-code
